# X (Twitter) OAuth 2.0 — create an app at https://developer.x.com
# App type: Web App / Confidential client. Required scopes: users.read tweet.read
X_CLIENT_ID=
X_CLIENT_SECRET=
# Must exactly match a Callback URL registered in the X app settings.
X_REDIRECT_URI=http://localhost:3000/auth/twitter/callback

# Long random string used to HMAC-sign card stats and the verification cookie.
# Generate e.g. with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=

# Optional
PORT=3000
